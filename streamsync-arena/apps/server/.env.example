PORT=3001
CORS_ORIGIN=http://localhost:5173
APP_PLAN_TIER=free
OPERATOR_TOKEN=
VIEWER_TOKEN=
BILLING_ACTIVE=true
BILLING_TRIAL_END=
BILLING_WEBHOOK_SECRET=
BILLING_WEBHOOK_SIGNING_SECRET=

# mock | youtube | twitch
CHAT_PLATFORM=mock

# YouTube mode
YOUTUBE_API_KEY=
YOUTUBE_LIVE_CHAT_ID=
YOUTUBE_STREAM_ID=

# Twitch mode
TWITCH_CHANNEL=
TWITCH_BOT_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_STREAM_ID=

# OBS WebSocket (optional: set when OBS integration is needed)
OBS_WS_ENABLED=false
OBS_WS_URL=
OBS_WS_PASSWORD=
OBS_EFFECT_SCENE=
OBS_VOTE_SOURCE_NAME=

# Mock adapter message interval in milliseconds (default: 2200)
MOCK_AUTO_MESSAGES=false
MOCK_MESSAGE_INTERVAL_MS=3500
MOCK_MESSAGE_START_DELAY_MS=1200

# Optional alert destination for platform/adapter errors (e.g. Discord webhook)
ALERT_WEBHOOK_URL=
